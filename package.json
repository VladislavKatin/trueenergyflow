{
  "name": "trueenergyflow",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "check": "npm run lint && npm run build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --max-warnings=0",
    "images:generate": "node scripts/generate-local-ai-images.mjs",
    "images:dry-run": "node scripts/generate-local-ai-images.mjs --dry-run",
    "images:generate:leonardo": "node scripts/generate-leonardo-images.mjs",
    "images:dry-run:leonardo": "node scripts/generate-leonardo-images.mjs --dry-run",
    "images:optimize": "node scripts/optimize-assets.mjs",
    "release": "node scripts/release.mjs",
    "autosync": "powershell -ExecutionPolicy Bypass -File scripts/autosync.ps1"
  },
  "dependencies": {
    "@next/mdx": "^15.2.0",
    "@supabase/supabase-js": "^2.49.8",
    "gray-matter": "^4.0.3",
    "next": "^15.2.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3"
  }
}
